{
  "name": "flamme-4",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "tauri": "tauri",
    "tauri:dev": "npm run icons && tauri dev",
    "tauri:build": "npm run icons && tauri build",
    "build:sidecar": "powershell -NoProfile -ExecutionPolicy Bypass -File ../flamme-backend/scripts/build_sidecar.ps1",
    "release:win": "npm run build:sidecar && npm run tauri:build",
    "create-shortcut": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-desktop-shortcut.ps1",
    "icons": "python branding/generate_app_icon.py && tauri icon branding/app-icon-square.png"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10",
    "@codemirror/lang-markdown": "^6.5",
    "@codemirror/language": "^6.12",
    "@codemirror/state": "^6.6",
    "@codemirror/view": "^6.43",
    "@lezer/highlight": "^1.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "lucide-react": "latest",
    "marked": "^18.0.4",
    "react": "^19",
    "react-dom": "^19",
    "react-force-graph-2d": "^1.29.1",
    "zustand": "^5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6",
    "tailwindcss": "^4",
    "typescript": "~6",
    "vite": "^8",
    "vitest": "^4"
  }
}
