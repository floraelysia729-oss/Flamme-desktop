# LLM-WIKI 配置 — 复制为 .env 并填入你的 API key

# --- Vault 路径 ---
# 优先级：插件 x-vault-path header > 环境变量 LLM_WIKI_VAULT > 自动检测 .obsidian/
# 一般不需要设置，后端会从当前目录向上查找 .obsidian/
# LLM_WIKI_VAULT=/path/to/your/obsidian/vault

# --- Chat LLM（推荐 DeepSeek）---
LLM_API_KEY=your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# --- Embedding（推荐阿里 DashScope text-embedding-v3）---
EMBED_API_KEY=your-dashscope-api-key
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBED_MODEL=text-embedding-v3
EMBED_DIM=1024

# --- Brain LLM（多 Agent 编排，DeepSeek）---
BRAIN_API_KEY=your-deepseek-api-key
BRAIN_BASE_URL=https://api.deepseek.com
BRAIN_MODEL=deepseek-chat

# --- MinerU（PDF 精准解析）---
MINERU_API_TOKEN=your-mineru-token

# --- Vision OCR（手写识别，可选，默认复用 EMBED key）---
# OCR_API_KEY=your-dashscope-api-key
# OCR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OCR_MODEL=qwen-vl-max

# --- 运行时 ---
LLM_MAX_CONCURRENCY=2
LLM_LOG_LEVEL=INFO

# --- 摄入依赖（非环境变量，pip install -e . 会自动安装）---
# jieba        — 实体页构建（entities/），已列入 pyproject.toml 主依赖
# comtypes     — Windows 下 PPT→PDF（需本机安装 Microsoft PowerPoint），Win 平台自动安装
# LibreOffice  — 无 PowerPoint 时的 PPT 转换备选（需 soffice 在 PATH 或标准安装路径）
# MINERU_API_TOKEN — PDF/Word 解析（见上）
# EMBED_API_KEY    — 向量嵌入（见上）；前端设置页也会通过 X-Embed-Key 传入
